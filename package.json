{
  "name": "modernize-next-nextauth",
  "version": "5.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:format": "dotenv -e .env.local -- prisma format",
    "db:validate": "dotenv -e .env.local -- prisma validate",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:reset": "dotenv -e .env.local -- prisma migrate reset",
    "db:fresh": "yarn db:generate && rm -rf prisma/migrations && yarn db:reset --force && yarn db:migrate --name init",
    "db:export": "dotenv -e .env.local -- tsx scripts/export-db-to-json.ts"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/groq": "^3.0.35",
